# =============================================================================
# Frontend (Vite + React) — environment template
#
# Copy to `.env.local` for local dev. NEVER commit `.env.local`.
# In production, set these in the Vercel dashboard under Project Settings -> Environment Variables.
#
# Only variables prefixed with VITE_ are exposed to client-side code.
# They are PUBLIC — anyone can read them in the browser. Do NOT put secrets here.
# =============================================================================

# Backend API base URL (no trailing slash).
# Local dev:  http://localhost:8000/api
# Production: https://<your-render-subdomain>.onrender.com/api
VITE_API_URL=http://localhost:8000/api
