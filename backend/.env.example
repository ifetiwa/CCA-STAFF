# =============================================================================
# Customary Court of Appeal · Staff Biodata Management System (Django backend)
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

# --- Core Django -------------------------------------------------------------
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_LOG_LEVEL=INFO

# --- PostgreSQL --------------------------------------------------------------
DB_NAME=biodata_system
DB_USER=biodata
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=60

# --- CORS (React dev server) -------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Uploads / Pillow --------------------------------------------------------
FILE_UPLOAD_MAX_MEMORY_SIZE=5242880
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
STAFF_PHOTO_MAX_WIDTH=800
STAFF_PHOTO_MAX_HEIGHT=800

# --- Auditlog ----------------------------------------------------------------
AUDITLOG_INCLUDE_ALL_MODELS=False

# --- Email -------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@cca.gov.ng

# --- Production-only ---------------------------------------------------------
# Set DJANGO_DEBUG=False in production and review these.
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
