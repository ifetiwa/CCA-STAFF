# shellcheck shell=bash
#
# Shared environment for every deploy/*.sh script.
# Copy to `env.deploy.sh` and edit before running anything.
#
# Each setting is intentionally a plain shell variable so the scripts can be
# `source`d.  Quote values that contain spaces.

# ---- Identity ---------------------------------------------------------------
APP_USER="biodata"
APP_GROUP="biodata"
APP_DIR="/opt/biodata"
VENV_DIR="${APP_DIR}/venv"
PROJECT_DIR="${APP_DIR}/backend"           # contains manage.py
LOG_DIR="/var/log/biodata"
RUN_DIR="/run/gunicorn"
SOCK_PATH="${RUN_DIR}/biodata.sock"

# ---- Source ----------------------------------------------------------------
# Where to clone the project from.  Use an internal git server or a tarball
# pulled from an air-gapped media.
REPO_URL="https://example.invalid/cca-staff.git"
REPO_BRANCH="main"

# ---- HTTP / TLS ------------------------------------------------------------
DOMAIN="biodata.cca.local"
TLS_DIR="/etc/ssl/biodata"
TLS_CERT="${TLS_DIR}/${DOMAIN}.crt"
TLS_KEY="${TLS_DIR}/${DOMAIN}.key"
TLS_DAYS=825                              # browser max for self-signed certs

# ---- Court LAN -------------------------------------------------------------
# Space-separated list of CIDRs that may reach the server.  Narrow this if
# your court network uses a single /24.
COURT_LAN_CIDRS=(192.168.0.0/16 10.0.0.0/8)

# ---- Database --------------------------------------------------------------
DB_NAME="biodata_prod"
DB_USER="biodata_app"
DB_HOST="localhost"
DB_PORT="5432"
# Leave DB_PASSWORD empty — the postgres setup script generates a random
# password and prints it once.  You then paste it into backend/.env.
DB_PASSWORD=""

# ---- Backups ---------------------------------------------------------------
BACKUP_DIR="/var/backups/biodata"
BACKUP_RETENTION_DAYS=30
BACKUP_CRON_TIME="15 2 * * *"            # 02:15 every day

# ---- Gunicorn --------------------------------------------------------------
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=60
