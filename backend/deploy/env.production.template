# =====================================================================
# CCA Biodata — production .env  (DJANGO process environment)
#
# Rendered by deploy/03_app_deploy.sh from this template.  Placeholders
# wrapped in __PLACEHOLDER__ are substituted at deploy time; everything
# else is yours to tune.  This file MUST stay mode 0640 owned by the app
# user.
# =====================================================================

DJANGO_SECRET_KEY=__SECRET_KEY__
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=__DOMAIN__,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://__DOMAIN__

# --- Database ---------------------------------------------------------
DB_NAME=__DB_NAME__
DB_USER=__DB_USER__
DB_PASSWORD=__DB_PASSWORD__
DB_HOST=__DB_HOST__
DB_PORT=__DB_PORT__
DB_CONN_MAX_AGE=60

# --- HTTPS / security -------------------------------------------------
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# --- CORS (React dev server typically not exposed in prod) ------------
CORS_ALLOWED_ORIGINS=https://__DOMAIN__

# --- Session ----------------------------------------------------------
SESSION_INACTIVITY_MINUTES=30

# --- Email (configure for your SMTP relay) ----------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.cca.local
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@cca.gov.ng

# --- Reports / branding ----------------------------------------------
COURT_NAME=Customary Court of Appeal, FCT
COURT_LOGO_PATH=/opt/biodata/backend/static/img/court_logo.png

# --- Audit thresholds (see audit/services.py) ------------------------
AUDIT_VIEWS_PER_HOUR_THRESHOLD=50
AUDIT_FAILED_LOGIN_THRESHOLD=5
AUDIT_FAILED_LOGIN_WINDOW_MIN=15
