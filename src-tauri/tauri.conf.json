{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CCA Staff Biodata",
  "version": "0.3.9",
  "identifier": "ng.gov.cca.staff",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CCA Staff Biodata Management System",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ifetiwa/CCA-STAFF/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg5RkEzRDNERDczREMzQUIKUldTcnd6M1hQVDM2aVhBY0NUaG5nN2xxYmtNL3l2UzRyMGJMOXlwL0lxb3RkWlEvK25ZWmcvSjgK"
    }
  }
}
